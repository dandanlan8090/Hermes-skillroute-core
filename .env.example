# Hermes Agent 环境变量示例（复制为 .env 后填入真实值）
# 本文件不入库，仅作占位模板

# 主模型 provider（OpenAI 兼容端点）
MODEL_PROVIDER=custom
MODEL_NAME=<main-model>
MODEL_BASE_URL=http://<proxy-host>:<port>/v1
MODEL_API_KEY=<api-key>

# vdb 检索嵌入（SiliconFlow BGE-M3 云端嵌入）
VDB_EMBED_API_KEY=<siliconflow-api-key>
VDB_EMBED_MODEL=BAAI/bge-m3

# 可选：外部 MCP 服务器密钥
# SCRAPLING_...=
# CODEBASE_MEMORY_...=
